{
    "name": "xzxzyzyz/laravel-japanese-validation",
    "description": "Japanese Validation For Laravel",
    "keywords": [
        "laravel",
        "validation",
        "都道府県",
        "郵便番号",
        "電話番号"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Xzxzyzyz",
            "email": "xzxzyzyz@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Xzxzyzyz\\Laravel\\JapaneseValidation\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
